# Copy to .env (gitignored). The app loads .env automatically at startup;
# real shell environment variables always win over this file.

# API tokens. satnogs_db_api_key and HUGGING_FACE_HUB_TOKEN are forwarded
# into the engine containers when set here, so one .env can drive everything.
satnogs_db_api_key=
satnogs_network_api_key=
HUGGING_FACE_HUB_TOKEN=

# Path to satnogs-signal's SQLite predictions store (read-only)
SATNOGS_SIGNAL_DB=/Users/ryan/GitHub/satnogs-signal/triage.db
# Dashboard's own cache/review-state DB
DASHBOARD_DB=./dashboard.db
# Sibling repo checkouts (used to build default engine commands)
SATNOGS_ID_DIR=/Users/ryan/GitHub/satnogs-id
SATNOGS_DECODER_DIR=/Users/ryan/GitHub/satnogs-decoder
# Optional full command overrides for the JSON runners (shlex-split)
#IDENTITY_CMD=
#DECODER_CMD=
# Tuning (defaults shown)
#P_HIGH=0.9
#P_LOW=0.5
#QUEUE_LIMIT=200
#JOB_WORKERS=2
#JOB_TIMEOUT_S=1800
#NETWORK_TTL_HOURS=24

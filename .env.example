# Path to satnogs-signal's SQLite predictions store (read-only)
SATNOGS_SIGNAL_DB=/Users/ryan/GitHub/satnogs-signal/triage.db
# Dashboard's own cache/review-state DB
DASHBOARD_DB=./dashboard.db
# Sibling repo checkouts (used to build default engine commands)
SATNOGS_ID_DIR=/Users/ryan/GitHub/satnogs-id
SATNOGS_DECODER_DIR=/Users/ryan/GitHub/satnogs-decoder
# Optional overrides: full command prefixes for the JSON runners (shlex-split).
# Defaults run the runners inside the sibling containers via docker compose.
#IDENTITY_CMD=
#DECODER_CMD=
# Optional token for SatNOGS Network reads (public reads work without it)
#SATNOGS_NETWORK_TOKEN=
